# Google Cloud / Vertex AI (Gemini 1.5)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
LOCATION=us-central1

# Mapbox (react-map-gl / deck.gl basemap token for dashboard)
MAPBOX_ACCESS_TOKEN=your-mapbox-token

# Dashboard (Vite) — copy to dashboard/.env.local
VITE_MAPBOX_ACCESS_TOKEN=your-mapbox-token
VITE_API_WS_URL=ws://localhost:8000/ws/simulation

# Optional: wall-clock seconds between simulation broadcasts (each tick = 12 simulated hours)
# SIM_HEARTBEAT_SECONDS=2
