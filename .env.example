# Google Cloud / Vertex AI (Gemini 1.5)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
LOCATION=us-central1

# Mapbox (react-map-gl / deck.gl basemap token for dashboard)
MAPBOX_ACCESS_TOKEN=your-mapbox-token

# Dashboard (Vite) — copy to dashboard/.env.local
VITE_MAPBOX_ACCESS_TOKEN=your-mapbox-token
VITE_API_WS_URL=ws://localhost:8000/ws/simulation
# VITE_MAPBOX_STYLE=mapbox://styles/mapbox/satellite-streets-v12

# Simulation (Python server) — handshake sent to dashboard on WS connect
# SIM_TICK_HOURS=12
# SIM_TICK_COUNT=14
# MISSION_HOURS=168
# SIM_EPOCH_UTC=2026-03-28T12:00:00Z
# RESIDENT_COUNT=5200
# RESIDENT_SEED=1337

# Optional: wall-clock seconds between server-driven steps when Play is on
# SIM_HEARTBEAT_SECONDS=2
