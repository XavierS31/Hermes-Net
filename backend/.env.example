# Copy to .env in this folder (next to main.py). Restart uvicorn after changes.
# Key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_key_here
# Optional alias (same value as above if you only have one line):
# GEMINI_API_KEY=your_key_here

# Optional: JSON URL returning hurricane forecast (see services/trajectory_forecast.py). If unset,
# the backend builds a forecast from the live simulation + approach corridor.
# HURRICANE_FORECAST_API_URL=https://example.com/my-storm-track.json
